# Docker Compose 运行示例
# 复制本文件为 .env：cp .env.docker.example .env
# DATABASE_URL 中的主机名 mysql_db 对应 docker-compose.yml 中的服务名，勿改动

DATABASE_URL=mysql+asyncmy://root:changeme@mysql_db:3306/fancy_agent
SECRET_KEY=change-this-to-a-random-secret-key
OSS_URL=http://localhost/files
UPLOAD_DIR=/data/uploads
WORKSPACE_DIR=/data/workspaces

# 搜索服务（默认 duckduckgo，无需 key；tavily 效果更好但需申请）
# SEARCH_PROVIDER=tavily
# TAVILY_API_KEY=your-tavily-api-key

# 邮件 Agent（可选，默认关闭）
# EMAIL_ENABLED=true
# EMAIL_PROVIDER=gmail
# EMAIL_ADDRESS=you@gmail.com
# EMAIL_USERNAME=you@gmail.com
# EMAIL_PASSWORD=your-app-password
